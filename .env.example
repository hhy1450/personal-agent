# DeepSeek API Configuration (text model)
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen-VL API Configuration (vision model, via DashScope)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
VISION_MODEL=qwen-vl-max

# LLM Model (deepseek-chat or deepseek-reasoner)
LLM_MODEL=deepseek-chat

# Workspace directory (relative to project root)
WORKSPACE_DIR=workspace

# MySQL connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=personal_agent

# API server
API_PORT=8000

# Log level
LOG_LEVEL=INFO
